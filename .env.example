# Copy to `.env`. The app reads these at runtime.

# --- Qwen (Alibaba Cloud Model Studio / DashScope) ---
# Get a key at https://dashscope.console.aliyun.com/ (intl: Model Studio).
DASHSCOPE_API_KEY=sk-your-dashscope-key
QWEN_MODEL=qwen-plus

# --- Alibaba Cloud Tablestore (the backend datastore) ---
OTS_ENDPOINT=https://your-instance.region.ots.aliyuncs.com
OTS_INSTANCE=your-instance-name
OTS_TABLE=qwendesk_tickets
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret
